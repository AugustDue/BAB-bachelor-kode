  alpha_t          = bab_alpha_t_tip,
  mean_beta_exante = 0.00,
  real_beta        = coef(bab_mod_tip)[2],
  volatility       = sd(bab_returns_tip$bab_exc_m, na.rm = TRUE) * sqrt(12) * 100,
  sharpe           = bab_sharpe_tip
)

