cat("\n=== Variant 2: Simple afkast ===\n")

ex_ante_beta_simple <- function(ret_exc_d, mkt_exc_d,
                                vol_window = 252, vol_min = 120,
                                corr_window = 5 * 252, corr_min = 750) {
  n <- length(ret_exc_d)
  betas <- rep(NA_real_, n)
  if (n <= corr_window) return(betas)
  
  simple3_i <- rep(NA_real_, n)
  simple3_m <- rep(NA_real_, n)
  for (j in 1:(n - 2)) {
    if (!is.na(ret_exc_d[j]) && !is.na(ret_exc_d[j+1]) && !is.na(ret_exc_d[j+2]))
      simple3_i[j] <- (1+ret_exc_d[j])*(1+ret_exc_d[j+1])*(1+ret_exc_d[j+2]) - 1
    if (!is.na(mkt_exc_d[j]) && !is.na(mkt_exc_d[j+1]) && !is.na(mkt_exc_d[j+2]))
      simple3_m[j] <- (1+mkt_exc_d[j])*(1+mkt_exc_d[j+1])*(1+mkt_exc_d[j+2]) - 1
  }
  for (i in (corr_window + 1):n) {
    vol_idx <- max(1, i - vol_window):(i - 1)
    mi <- !is.na(ret_exc_d[vol_idx]); mm <- !is.na(mkt_exc_d[vol_idx])
    if (sum(mi) < vol_min || sum(mm) < vol_min) next
    sigma_i <- sd(ret_exc_d[vol_idx][mi])
    sigma_m <- sd(mkt_exc_d[vol_idx][mm])
    if (is.na(sigma_m) || sigma_m == 0) next
    ci <- max(1, i - corr_window):(i - 1)
    cm <- !is.na(simple3_i[ci]) & !is.na(simple3_m[ci])
    if (sum(cm) < corr_min) next
    rho <- cor(simple3_i[ci][cm], simple3_m[ci][cm])
    betas[i] <- rho * (sigma_i / sigma_m)
  }
  return(betas)
}

