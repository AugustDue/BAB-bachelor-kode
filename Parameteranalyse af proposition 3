# =============================================================================
# PROP 3 SAMMENLIGNINGSTABEL — 5-variabel regression for hver stresstest
#
# Forudsætter at bab_v1–bab_v5 og euribor_ois er defineret
# =============================================================================

run_prop3_reg5 <- function(bab_ret) {
  p3 <- bab_ret %>%
    filter(year_month >= "1994-01" & year_month <= "2021-12") %>%
    mutate(beta_spread = (beta_H - beta_L) / (beta_H * beta_L)) %>%
    left_join(euribor_ois %>% select(year_month, euribor_ois), by = "year_month") %>%
    arrange(year_month) %>%
    mutate(
      lag_ted         = lag(euribor_ois),
      change_ted      = euribor_ois - lag(euribor_ois),
      lag_bab         = lag(bab_exc_m),
      lag_beta_spread = lag(beta_spread),
      z_lag_ted         = as.numeric(scale(lag_ted)),
      z_change_ted      = as.numeric(scale(change_ted)),
      z_lag_beta_spread = as.numeric(scale(lag_beta_spread)),
      z_lag_bab         = as.numeric(scale(lag_bab)),
      z_mkt             = as.numeric(scale(mkt_exc_m))
    ) %>%
    filter(!is.na(lag_ted) & !is.na(change_ted))
  
  mod <- lm(bab_exc_m ~ z_lag_ted + z_change_ted +
              z_lag_beta_spread + z_lag_bab + z_mkt, data = p3)
  coefs <- summary(mod)$coefficients
  
  vars <- c("z_lag_ted", "z_change_ted", "z_lag_beta_spread", "z_lag_bab", "z_mkt")
  list(
    est = setNames(coefs[vars, 1], vars),
    tst = setNames(coefs[vars, 3], vars)
  )
}

