# PROPOSITION 3 — STRESSTEST (5 robusthedsanalyser)
#
# Forudsætter at Prop1 (original) er kørt, så følgende er tilgængelige:
#   daglig, aktie_måned, mkt_exc_måned, rf_måned, marked_daglig,
#   rf_daglig, w_fast, sigma2_xs, sigma2_ts, assign_deciles,
#   euribor_ois (fra Prop3), ex_ante_beta_ewma (fra EWMA-kode)
#
# De 5 tabeller:
#   (1) Ekskludering af de 10% mindste virksomheder (market equity)
#   (2) Simple afkast i stedet for logaritmiske
#   (3) EWMA beta (lambda = 0.97)
#   (4) Værdivægtet BAB
#   (5) Varierende shrinkage (Vasicek)
# =============================================================================

# ── HJÆLPEFUNKTION 1: Prop3-regressioner og tabel ────────────────────────────

run_prop3_tabel <- function(bab_ret, titel) {
  
  p3 <- bab_ret %>%
    filter(year_month >= "1994-01" & year_month <= "2021-12") %>%
    mutate(beta_spread = (beta_H - beta_L) / (beta_H * beta_L)) %>%
    left_join(euribor_ois %>% select(year_month, euribor_ois), by = "year_month") %>%
    arrange(year_month) %>%
    mutate(
      lag_ted         = lag(euribor_ois),
      change_ted      = euribor_ois - lag(euribor_ois),
      lag_bab         = lag(bab_exc_m),
      lag_beta_spread = lag(beta_spread),
      z_lag_ted         = as.numeric(scale(lag_ted)),
      z_change_ted      = as.numeric(scale(change_ted)),
      z_lag_beta_spread = as.numeric(scale(lag_beta_spread)),
      z_lag_bab         = as.numeric(scale(lag_bab)),
      z_mkt             = as.numeric(scale(mkt_exc_m))
    ) %>%
    filter(!is.na(lag_ted) & !is.na(change_ted))
  
  model_1 <- lm(bab_exc_m ~ z_lag_ted + z_change_ted, data = p3)
  model_2 <- lm(bab_exc_m ~ z_lag_ted + z_change_ted +
                  z_lag_beta_spread + z_lag_bab + z_mkt, data = p3)
  
  get_stat <- function(mod, var) {
    coefs <- summary(mod)$coefficients
    if (var %in% rownames(coefs))
      list(est = coefs[var, 1], tst = coefs[var, 3])
    else
      list(est = NA_real_, tst = NA_real_)
  }
  
  vars <- list(
    list(label = "Lagged EURIBOR-OIS spread",    z = "z_lag_ted"),
    list(label = "Change in EURIBOR-OIS spread", z = "z_change_ted"),
    list(label = "Beta spread",                  z = "z_lag_beta_spread"),
    list(label = "Lagged BAB return",             z = "z_lag_bab"),
    list(label = "Market return",                 z = "z_mkt")
  )
  
  rows <- list()
  for (v in vars) {
    s1 <- get_stat(model_1, v$z)
    s2 <- get_stat(model_2, v$z)
    rows[[length(rows) + 1]] <- data.frame(
      Variable = v$label, type = "est",
      Col1 = s1$est, Col2 = s2$est, stringsAsFactors = FALSE
    )
    rows[[length(rows) + 1]] <- data.frame(
      Variable = "", type = "tst",
      Col1 = s1$tst, Col2 = s2$tst, stringsAsFactors = FALSE
    )
  }
  tdf <- bind_rows(rows)
  tdf <- bind_rows(
    tdf,
    data.frame(Variable = "Number of observations", type = "info",
               Col1 = nrow(p3), Col2 = nrow(p3)),
    data.frame(Variable = "Adjusted R²", type = "info",
               Col1 = summary(model_1)$adj.r.squared,
               Col2 = summary(model_2)$adj.r.squared)
  )
  
  tdisp <- tdf %>%
    mutate(
      Col1_fmt = case_when(
        type == "tst"  & !is.na(Col1) ~ sprintf("(%.2f)", Col1),
        type == "info" & Variable == "Number of observations" ~ sprintf("%.0f", Col1),
        type == "info" ~ sprintf("%.3f", Col1),
        !is.na(Col1)   ~ sprintf("%.3f", Col1),
        TRUE ~ ""
      ),
      Col2_fmt = case_when(
        type == "tst"  & !is.na(Col2) ~ sprintf("(%.2f)", Col2),
        type == "info" & Variable == "Number of observations" ~ sprintf("%.0f", Col2),
        type == "info" ~ sprintf("%.3f", Col2),
        !is.na(Col2)   ~ sprintf("%.3f", Col2),
        TRUE ~ ""
      )
    ) %>%
    select(Variable, Col1 = Col1_fmt, Col2 = Col2_fmt)
  
  sig1 <- which(tdf$type == "est" & !is.na(tdf$Col1) & abs(lead(tdf$Col1)) > 1.96)
  sig2 <- which(tdf$type == "est" & !is.na(tdf$Col2) & abs(lead(tdf$Col2)) > 1.96)
  
  tgt <- tdisp %>%
    gt() %>%
    tab_header(title = titel) %>%
    cols_label(Variable = "", Col1 = "(1)", Col2 = "(2)") %>%
    cols_align(align = "right", columns = c(Col1, Col2)) %>%
    cols_align(align = "left",  columns = Variable) %>%
    tab_style(
      style     = cell_borders(sides = "all", style = "hidden"),
      locations = cells_body()
    )
  
  if (length(sig1) > 0)
    tgt <- tgt %>% tab_style(cell_text(weight = "bold"),
                             cells_body(rows = sig1, columns = "Col1"))
  if (length(sig2) > 0)
    tgt <- tgt %>% tab_style(cell_text(weight = "bold"),
                             cells_body(rows = sig2, columns = "Col2"))
  
  tgt <- tgt %>%
    tab_footnote(
      footnote  = "t-statistikker i parentes. Fed angiver signifikans ved 5% niveau.",
      locations = cells_title(groups = "title")
    ) %>%
    opt_table_font(font = "Arial") %>%
    tab_options(
      table.font.size         = 12,
      heading.title.font.size = 14,
      column_labels.font.weight = "bold",
      data_row.padding        = px(1)
    )
  
  print(tgt)
  invisible(tgt)
}

# ── HJÆLPEFUNKTION 2: Byg BAB fra data_prop1-lignende datasæt ────────────────

build_bab_rank <- function(data_p) {
  bab_list     <- list()
  alle_maaned  <- sort(unique(data_p$year_month))
  for (i in seq_along(alle_maaned)) {
    hold_m   <- alle_maaned[i]
    aktier_i <- data_p %>%
      filter(year_month == hold_m,
             !is.na(beta_sort), is.finite(beta_sort),
             !is.na(ret_m), !is.na(rf_m))
    if (nrow(aktier_i) < 2) next
    aktier_i <- aktier_i %>%
      mutate(
        z     = rank(beta_sort),
        z_bar = mean(z),
        k     = 2 / sum(abs(z - z_bar)),
        w_H   = pmax(k * (z - z_bar), 0),
        w_L   = pmax(k * (z_bar - z), 0)
      )
    r_L    <- sum(aktier_i$w_L * aktier_i$ret_m)
    r_H    <- sum(aktier_i$w_H * aktier_i$ret_m)
    beta_L <- sum(aktier_i$w_L * aktier_i$beta_sort)
    beta_H <- sum(aktier_i$w_H * aktier_i$beta_sort)
    if (beta_L <= 0 | beta_H <= 0) next
    rf_val    <- first(aktier_i$rf_m)
    bab_exc_m <- (1 / beta_L) * (r_L - rf_val) - (1 / beta_H) * (r_H - rf_val)
    bab_list[[i]] <- data.frame(
      year_month = hold_m, bab_exc_m = bab_exc_m,
      mkt_exc_m  = first(aktier_i$mkt_exc_m),
      rf_m = rf_val, beta_L = beta_L, beta_H = beta_H
    )
  }
  bind_rows(bab_list) %>% arrange(year_month) %>% filter(!is.na(bab_exc_m))
}

# ── HJÆLPEFUNKTION 3: Beta → månedlig data_prop1 pipeline ────────────────────
# Bruges af varianterne der genberegner beta fra bunden

build_data_prop1_from_daglig <- function(daglig_v, aktie_maaned_v) {
  beta_m <- daglig_v %>%
    filter(!is.na(beta_exante)) %>%
    mutate(year_month = format(date, "%Y-%m")) %>%
    group_by(id, year_month) %>%
    summarise(beta_sort = last(beta_exante), .groups = "drop") %>%
    mutate(year_month = format(
      as.Date(paste0(year_month, "-01")) %m+% months(1), "%Y-%m"
    ))
  aktie_maaned_v %>%
    left_join(beta_m, by = c("id", "year_month")) %>%
    filter(!is.na(beta_sort), !is.na(ret_exc_m), !is.na(mkt_exc_m),
           is.finite(beta_sort)) %>%
    group_by(year_month) %>%
    mutate(beta_decil = assign_deciles(beta_sort)) %>%
    ungroup()
}

