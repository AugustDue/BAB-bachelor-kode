cat("\n=== Variant 5: Varierende shrinkage (Vasicek) ===\n")

# Kræver sigma2_xs og sigma2_ts på daglig (beregnet i original Prop1)
daglig_v5 <- daglig %>%
  mutate(beta_exante = ifelse(
    !is.na(beta_ts) & !is.na(sigma2_xs) & !is.na(sigma2_ts) &
      (sigma2_xs + sigma2_ts) > 0,
    (sigma2_xs / (sigma2_xs + sigma2_ts)) * beta_ts +
      (1 - sigma2_xs / (sigma2_xs + sigma2_ts)) * 1,
    NA_real_
  ))

