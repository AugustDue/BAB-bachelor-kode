# ── STEP 11: Konstruktion af BAB med gemte vægte ────────────────────────────

bab_list    <- list()
weight_list <- list()    # GEM VÆGTE TIL TURNOVER
alle_måneder <- sort(unique(data_prop1$year_month))

for (i in seq_along(alle_måneder)) {
  hold_m <- alle_måneder[i]
  
  aktier_i <- data_prop1 %>%
    filter(year_month == hold_m,
           !is.na(beta_sort), is.finite(beta_sort),
           !is.na(ret_m), !is.na(rf_m))
  if (nrow(aktier_i) < 2) next
  
  # ── Z-score ranking ──
  aktier_i <- aktier_i %>%
    mutate(
      z     = rank(beta_sort),
      z_bar = mean(z),
      k     = 2 / sum(abs(z - z_bar)),
      w_H   = pmax(k * (z - z_bar), 0),
      w_L   = pmax(k * (z_bar - z), 0)
    )
  
  # ── Porteføljeafkast ──
  r_L <- sum(aktier_i$w_L * aktier_i$ret_m)
  r_H <- sum(aktier_i$w_H * aktier_i$ret_m)
  
  # ── Porteføljebetaer ──
  beta_L <- sum(aktier_i$w_L * aktier_i$beta_sort)
  beta_H <- sum(aktier_i$w_H * aktier_i$beta_sort)
  
  if (beta_L <= 0 | beta_H <= 0) next
  
  # ── Fælles risikofri rente for måneden ──
  rf_m <- first(aktier_i$rf_m)
  
  # ── BAB-afkast ──
  bab_exc_m <- (1 / beta_L) * (r_L - rf_m) - (1 / beta_H) * (r_H - rf_m)
  
  bab_list[[i]] <- data.frame(
    year_month  = hold_m,
    bab_exc_m   = bab_exc_m,
    mkt_exc_m   = first(aktier_i$mkt_exc_m),
    rf_m        = rf_m,
    r_L         = r_L,
    r_H         = r_H,
    beta_L      = beta_L,
    beta_H      = beta_H
  )
  
  # ── Gem vægte til turnover-beregning ──
  # Faktiske BAB-vægte inkl. leverage-skalering
  weight_list[[i]] <- data.frame(
    year_month = hold_m,
    id         = aktier_i$id,
    w_L        = aktier_i$w_L / beta_L,   # long-side (leveret)
    w_H        = aktier_i$w_H / beta_H    # short-side (leveret)
  )
}

bab_returns <- bind_rows(bab_list) %>%
  arrange(year_month) %>%
  filter(!is.na(bab_exc_m))

all_weights <- bind_rows(weight_list) %>%
  arrange(year_month, id)


# ── STEP 12: Turnover-beregning ──────────────────────────────────────────────
# Turnover_t = (1/2) * sum_i |w_{i,t} - w_{i,t-1}|
# Beregnes separat for long-side og short-side, samt total BAB

turnover_list <- list()
sorted_months <- sort(unique(all_weights$year_month))

for (j in 2:length(sorted_months)) {
  m_curr <- sorted_months[j]
  m_prev <- sorted_months[j - 1]
  
  w_curr <- all_weights %>% filter(year_month == m_curr)
  w_prev <- all_weights %>% filter(year_month == m_prev)
  
  # Fuld join: aktier der kun er i én periode får vægt 0 i den anden
  merged <- full_join(
    w_curr %>% select(id, w_L_curr = w_L, w_H_curr = w_H),
    w_prev %>% select(id, w_L_prev = w_L, w_H_prev = w_H),
    by = "id"
  ) %>%
    mutate(
      w_L_curr = replace_na(w_L_curr, 0),
      w_L_prev = replace_na(w_L_prev, 0),
      w_H_curr = replace_na(w_H_curr, 0),
      w_H_prev = replace_na(w_H_prev, 0)
    )
  
  # Turnover per side (standard definition: 1/2 * sum |delta w|)
  turnover_L <- 0.5 * sum(abs(merged$w_L_curr - merged$w_L_prev))
  turnover_H <- 0.5 * sum(abs(merged$w_H_curr - merged$w_H_prev))
  
  # Total BAB turnover = long-side + short-side
  turnover_total <- turnover_L + turnover_H
  
  turnover_list[[j]] <- data.frame(
    year_month     = m_curr,
    turnover_long  = turnover_L,
    turnover_short = turnover_H,
    turnover_total = turnover_total
  )
}

turnover_df <- bind_rows(turnover_list) %>%
  arrange(year_month)

# ── Turnover-opsummering (annualiseret = 12 * månedlig) ──
