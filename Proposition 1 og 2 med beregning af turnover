  Metric = c("Merafkast", "t-stat", "CAPM alpha", "t-stat",
             "Beta (ex ante)", "Beta (realiseret)", "Volatilitet", "Sharpe ratio")
)

for (d in 1:10) {
  row <- decil_tabel %>% filter(beta_decil == d)
  tabel_df[[paste0("P", d)]] <- c(
    row$mean_exc_pct,
    row$t_excess,
    row$alpha_pct,
    row$alpha_t,
    row$mean_beta_exante,
    row$real_beta,
    row$volatility,
    row$sharpe
  )
}

tabel_df[["BAB"]] <- c(
  bab_stats$mean_exc_pct,
  bab_stats$t_excess,
  bab_stats$alpha_pct,
  bab_stats$alpha_t,
  bab_stats$mean_beta_exante,
  bab_stats$real_beta,
  bab_stats$volatility,
  bab_stats$sharpe
)

tabel_df <- tabel_df %>%
  mutate(across(where(is.numeric), ~ round(., 2)))

