print(p2)

# Plot 3: Tidsserie af BAB og Euribor-OIS spread
prop3_ts <- prop3_data %>%
  select(year_month, bab_exc_m, euribor_ois) %>%
  mutate(
    bab_scaled = as.numeric(scale(bab_exc_m)),
    ted_scaled = as.numeric(scale(euribor_ois))
  ) %>%
  pivot_longer(cols = c(bab_scaled, ted_scaled),
               names_to  = "serie",
               values_to = "værdi") %>%
  mutate(serie = recode(serie,
                        "bab_scaled" = "BAB merafkast (skaleret)",
                        "ted_scaled" = "EURIBOR-OIS spread (skaleret)"))

p3 <- ggplot(prop3_ts,
             aes(x = as.Date(paste0(year_month, "-01")),
                 y = værdi, color = serie)) +
  geom_line(alpha = 0.8) +
  scale_color_manual(values = c("BAB merafkast (skaleret)"      = "#2196F3",
                                "EURIBOR-OIS spread (skaleret)" = "#f85149")) +
  labs(title = "BAB-merafkast og EURIBOR-OIS spread (1994-2022)",
       x = "år", y = "Skaleret værdi", color = "") +
  theme_minimal() +
  theme(legend.position = "bottom")
print(p3)
