p2 <- ggplot(prop3_data, aes(x = change_ted, y = bab_exc_m)) +
  geom_point(alpha = 0.4) +
  geom_smooth(method = "lm", se = TRUE, color = "blue") +
  labs(title = "BAB-merafkast vs ændring i Euribor-OIS spread",
