    .groups = "drop"
  ) %>%
  filter(is.finite(mean_ret) & is.finite(mean_beta_exante))

mod_ii        <- lm(mean_ret ~ mean_beta_exante, data = aktie_summary)
sml_hældning <- coef(mod_ii)["mean_beta_exante"]

cat(sprintf("Antal aktier i SML-regression: %d\n", nrow(aktie_summary)))

p1 <- ggplot(aktie_summary, aes(x = mean_beta_exante, y = mean_ret)) +
  geom_point(alpha = 0.15, size = 0.6, color = "gray40") +
