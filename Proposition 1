  geom_hline(yintercept = 0, linetype = "dashed", color = "gray70") +
  coord_cartesian(
    xlim = c(0, quantile(aktie_summary$mean_beta_exante, 0.99, na.rm = TRUE)),
    ylim = c(quantile(aktie_summary$mean_ret, 0.01, na.rm = TRUE),
             quantile(aktie_summary$mean_ret, 0.99, na.rm = TRUE))
  ) +
  annotate("text",
           x     = quantile(aktie_summary$mean_beta_exante, 0.85, na.rm = TRUE),
           y     = lambda * quantile(aktie_summary$mean_beta_exante, 0.85, na.rm = TRUE) * 1.4,
           label = "Teoretisk SML",
